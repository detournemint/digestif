<div class="mx-auto max-w-lg w-full">
  <div class="text-center mb-8">
    <h1 class="font-serif text-3xl font-bold">Edit Profile</h1>
  </div>

  <hr class="newspaper-rule mb-8">

  <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-5" do |f| %>
    <% if @user.errors.any? %>
      <div class="border border-accent/30 bg-red-50 px-4 py-3">
        <% @user.errors.full_messages.each do |msg| %>
          <p class="text-accent text-sm italic"><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div>
      <%= f.label :display_name, "Display Name", class: "block text-xs uppercase tracking-widest text-ink-faded mb-1 font-serif" %>
      <%= f.text_field :display_name, placeholder: "How you'd like to be known", class: "w-full border border-rule bg-cream px-3 py-2 font-body focus:outline-none focus:border-rule-dark" %>
    </div>

    <div>
      <%= f.label :bio, "About", class: "block text-xs uppercase tracking-widest text-ink-faded mb-1 font-serif" %>
      <%= f.text_area :bio, rows: 3, placeholder: "A few words about yourself", class: "w-full border border-rule bg-cream px-3 py-2 font-body focus:outline-none focus:border-rule-dark resize-none" %>
    </div>

    <div>
      <%= f.label :location, class: "block text-xs uppercase tracking-widest text-ink-faded mb-1 font-serif" %>
      <%= f.text_field :location, placeholder: "Where you're based", class: "w-full border border-rule bg-cream px-3 py-2 font-body focus:outline-none focus:border-rule-dark" %>
    </div>

    <div>
      <%= f.label :interests, class: "block text-xs uppercase tracking-widest text-ink-faded mb-1 font-serif" %>
      <%= f.text_field :interests, placeholder: "cooking, reading, cycling, ...", class: "w-full border border-rule bg-cream px-3 py-2 font-body focus:outline-none focus:border-rule-dark" %>
      <p class="text-xs text-ink-faded mt-1 italic">Comma-separated</p>
    </div>

    <%= f.submit "Save", class: "w-full bg-ink hover:bg-ink-light text-cream font-serif font-bold py-2.5 px-4 cursor-pointer transition text-sm tracking-widest uppercase" %>
  <% end %>
</div>
